model Role {
    id          String     @id @default(uuid())
    name        String     @unique
    description String?
    createdAt   DateTime   @default(now()) @map("created_at")
    updatedAt   DateTime   @updatedAt @map("updated_at")
    deletedAt   DateTime?  @map("deleted_at")
    userRoles   UserRole[]

    @@map("roles")
    rolePermissions RolePermission[]
}
